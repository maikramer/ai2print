# Clified registry — ai2print (GTK GUI + Python repair pipeline)

workspace:
  root: .
  name: "ai2print"

tools:
  ai2print:
    name: "AI2Print"
    kind: rust
    folder: .
    cli_name: ai2print
    cargo_bin_name: stl-repair-gui
    description: "GTK GUI to repair STL/3MF meshes for 3D printing"
    extra_aliases: [stl-repair-gui]
    post_install: clified_install:post_install
